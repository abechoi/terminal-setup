#!/bin/bash
# power — Mac power management for IB Gateway overnight sessions

set -e

REAL_HOME=$(eval echo ~${SUDO_USER:-$USER})
PLIST="$REAL_HOME/Library/LaunchAgents/com.ibkr.nosleep.plist"

R='\033[0;31m' G='\033[0;32m' Y='\033[1;33m' C='\033[0;36m'
DIM='\033[2m' B='\033[1m' X='\033[0m'

# ── Status ───────────────────────────────────────────────────────────────

detect_profile() {
    local sleep_val=$(pmset -g | awk '/^ sleep / {print $2}')
    local disp_val=$(pmset -g | awk '/^ displaysleep/ {print $2}')
    local caff=$(pgrep -f "caffeinate -dims" >/dev/null 2>&1 && echo "yes" || echo "no")
    local lock=$(defaults read com.apple.screensaver askForPassword 2>/dev/null || echo "1")

    if [ "$sleep_val" != "0" ]; then
        echo "default"
    elif [ "$caff" = "no" ]; then
        echo "moderate"
    elif [ "$lock" = "0" ]; then
        echo "nuclear"
    else
        echo "aggressive"
    fi
}

show_status() {
    local profile=$(detect_profile)
    local sleep_val=$(pmset -g | awk '/^ sleep / {print $2}')
    local disp_val=$(pmset -g | awk '/^ displaysleep/ {print $2}')
    local caff=$(pgrep -f "caffeinate -dims" >/dev/null 2>&1 && echo "running" || echo "off")

    local color=$G
    case $profile in
        moderate)   color=$Y ;;
        aggressive) color=$R ;;
        nuclear)    color="${R}${B}" ;;
    esac

    echo ""
    echo -e "  Profile:     ${color}${profile}${X}"
    echo -e "  Sleep:       ${sleep_val} ${DIM}(0=never)${X}"
    echo -e "  Display:     ${disp_val} ${DIM}(0=never)${X}"
    echo -e "  Caffeinate:  ${caff}"
    echo ""
}

# ── Caffeinate LaunchAgent ───────────────────────────────────────────────

install_caffeinate() {
    cat > "$PLIST" << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ibkr.nosleep</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/caffeinate</string>
        <string>-dims</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
</dict>
</plist>
EOF
    chown "${SUDO_USER:-$USER}" "$PLIST"
    sudo -u "${SUDO_USER:-$USER}" launchctl load "$PLIST" 2>/dev/null || true
}

remove_caffeinate() {
    if [ -f "$PLIST" ]; then
        sudo -u "${SUDO_USER:-$USER}" launchctl unload "$PLIST" 2>/dev/null || true
        rm -f "$PLIST"
    fi
    killall caffeinate 2>/dev/null || true
}

# ── Profiles ─────────────────────────────────────────────────────────────

do_default() {
    remove_caffeinate
    pmset -a sleep 1 displaysleep 10 disksleep 10
    pmset -a hibernatemode 3 standby 1 autopoweroff 1
    pmset -a powernap 1 proximitywake 1
    pmset -a tcpkeepalive 1 ttyskeepawake 1 womp 1
    pmset -b sleep 1 displaysleep 2 disksleep 10 standby 1
    sudo -u "${SUDO_USER:-$USER}" defaults write com.apple.screensaver askForPassword -int 1
    sudo -u "${SUDO_USER:-$USER}" defaults write com.apple.screensaver idleTime -int 300
    echo -e "  ${G}Done.${X} Normal Mac behavior. IB Gateway will disconnect overnight."
}

do_moderate() {
    remove_caffeinate
    pmset -c sleep 0 displaysleep 30 disksleep 0
    pmset -c hibernatemode 0 standby 0 autopoweroff 0
    pmset -c powernap 0 proximitywake 0
    pmset -c tcpkeepalive 1 ttyskeepawake 1 womp 1
    pmset -b sleep 0 displaysleep 5 disksleep 0
    pmset -b hibernatemode 0 standby 0
    echo -e "  ${G}Done.${X} No sleep, display dims after 30 min."
    echo -e "  ${Y}Idle sleep may still kick in overnight — use 'aggressive' for that.${X}"
}

do_aggressive() {
    pmset -a sleep 0 displaysleep 0 disksleep 0
    pmset -a hibernatemode 0 standby 0 autopoweroff 0
    pmset -a powernap 0 proximitywake 0
    pmset -a tcpkeepalive 1 ttyskeepawake 1 womp 1
    install_caffeinate
    echo -e "  ${G}Done.${X} Everything off + caffeinate running forever."
    echo -e "  ${G}IB Gateway will stay connected overnight.${X}"
}

do_nuclear() {
    do_aggressive 2>/dev/null
    sudo -u "${SUDO_USER:-$USER}" defaults write com.apple.screensaver askForPassword -int 0
    sudo -u "${SUDO_USER:-$USER}" defaults write com.apple.screensaver idleTime -int 0
    defaults write .GlobalPreferences com.apple.autologout.AutoLogOutDelay -int 0
    echo -e "  ${G}Done.${X} Aggressive + screen lock disabled."
    echo -e "  ${R}No password required. Machine fully exposed.${X}"
}

# ── Help ─────────────────────────────────────────────────────────────────

show_help() {
    echo ""
    echo -e "  ${B}power${X} — keep your Mac awake for IB Gateway"
    echo ""
    echo -e "  ${B}COMMANDS${X}"
    echo -e "    power ${G}default${X}       Normal Mac. Sleeps, dims, hibernates."
    echo -e "    power ${Y}moderate${X}      No sleep. Display dims after 30 min."
    echo -e "    power ${R}aggressive${X}    No sleep + caffeinate. ${B}Use before bed.${X}"
    echo -e "    power ${R}nuclear${X}       Aggressive + screen lock off."
    echo -e "    power status         What's active right now."
    echo ""
    echo -e "  ${B}WHAT'S THE DIFFERENCE?${X}"
    echo ""
    echo -e "    ${G}default${X}      Safe for daily use. Mac sleeps normally."
    echo -e "    ${Y}moderate${X}     Good enough for daytime. May not survive overnight."
    echo -e "    ${R}aggressive${X}   Bulletproof overnight. Blocks the macOS idle-sleep"
    echo -e "                 bug that ignores pmset. This is the one you want."
    echo -e "    ${R}nuclear${X}      Same + disables screen lock. Only if aggressive fails."
    echo ""
    echo -e "  ${B}TYPICAL WORKFLOW${X}"
    echo -e "    Before bed:   sudo power aggressive"
    echo -e "    Next morning:  sudo power moderate  ${DIM}(or default)${X}"
    echo ""
}

# ── Main ─────────────────────────────────────────────────────────────────

case "${1:-}" in
    status)                    show_status ; exit 0 ;;
    help|-h|--help|"")         show_help   ; exit 0 ;;
esac

if [ "$EUID" -ne 0 ]; then
    echo -e "\n  ${R}Needs sudo:${X}  sudo power $1\n"
    exit 1
fi

echo ""
case "$1" in
    default)    do_default    ;;
    moderate)   do_moderate   ;;
    aggressive) do_aggressive ;;
    nuclear)    do_nuclear    ;;
    *)
        echo -e "  ${R}Unknown:${X} $1"
        show_help
        exit 1
        ;;
esac

show_status
